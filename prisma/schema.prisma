generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model ProductCategory {
  id       String  @id @default(cuid())
  name     String
  slug     String  @unique
  parentId String?

  parent   ProductCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children ProductCategory[] @relation("CategoryHierarchy")

  attributeDefinitions ProductAttributeDefinition[]
  canonicalProducts    CanonicalProduct[]
  basketItems          BasketItem[]

  createdAt DateTime @default(now())
}

model ProductAttributeDefinition {
  id             String @id @default(cuid())
  categoryId     String
  key            String
  label          String
  type           String // text, number, enum, boolean
  possibleValues String // JSON array of possible values
  sortOrder      Int    @default(0)

  category ProductCategory @relation(fields: [categoryId], references: [id])

  @@unique([categoryId, key])
}

model CanonicalProduct {
  id             String  @id @default(cuid())
  categoryId     String
  name           String
  normalizedName String
  brand          String?
  barcode        String? // ItemCode from supermarket XML for cross-chain matching
  metadata       String  @default("{}") // JSON
  searchableText String
  isActive       Boolean @default(true)

  category            ProductCategory      @relation(fields: [categoryId], references: [id])
  supermarketProducts SupermarketProduct[]
  basketItems         BasketItem[]

  createdAt DateTime @default(now())
}

model Supermarket {
  id              String    @id @default(cuid())
  name            String
  slug            String    @unique
  logoUrl         String?
  isActive        Boolean   @default(true)
  lastIngestionAt DateTime?

  products    SupermarketProduct[]
  dataSources DataSource[]

  createdAt DateTime @default(now())
}

model SupermarketProduct {
  id                 String  @id @default(cuid())
  supermarketId      String
  canonicalProductId String
  externalName       String
  brand              String?
  unit               String?
  size               String?
  price              Float // cached latest price for fast reads
  inStock            Boolean @default(true)
  isPromo            Boolean @default(false)
  promoDescription   String?
  metadata           String  @default("{}") // JSON
  updatedAt          DateTime @default(now())

  supermarket      Supermarket      @relation(fields: [supermarketId], references: [id])
  canonicalProduct CanonicalProduct @relation(fields: [canonicalProductId], references: [id])
  priceSnapshots   PriceSnapshot[]

  @@index([supermarketId])
  @@index([canonicalProductId])
}

model PriceSnapshot {
  id                   String   @id @default(cuid())
  supermarketProductId String
  price                Float
  currency             String   @default("ILS")
  isPromo              Boolean  @default(false)
  promoDescription     String?
  inStock              Boolean  @default(true)
  capturedAt           DateTime @default(now())

  supermarketProduct SupermarketProduct @relation(fields: [supermarketProductId], references: [id], onDelete: Cascade)

  @@index([supermarketProductId, capturedAt])
}

model DataSource {
  id            String  @id @default(cuid())
  supermarketId String
  type          String  // mock, scraper, api
  config        String  @default("{}") // JSON
  isActive      Boolean @default(true)

  supermarket Supermarket @relation(fields: [supermarketId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([supermarketId])
}

model Basket {
  id        String       @id @default(cuid())
  items     BasketItem[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model BasketItem {
  id                       String  @id @default(cuid())
  basketId                 String
  categoryId               String
  quantity                 Int     @default(1)
  matchMode                String  // exact, flexible
  selectedCanonicalProductId String?
  userConstraints          String  @default("{}") // JSON
  displayName              String

  basket           Basket            @relation(fields: [basketId], references: [id], onDelete: Cascade)
  category         ProductCategory   @relation(fields: [categoryId], references: [id])
  selectedProduct  CanonicalProduct? @relation(fields: [selectedCanonicalProductId], references: [id])

  createdAt DateTime @default(now())

  @@index([basketId])
}
